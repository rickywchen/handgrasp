<mujoco model="panda_table_scene">

  <!-- Force mesh resolution from the SCENE (most reliable on Windows) -->
  <compiler
      angle="radian"
      autolimits="true"
      meshdir="../models/franka_emika_panda/assets"
      texturedir="../models/franka_emika_panda/assets"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="1280" offheight="720"/>
  </visual>

  <!-- Include the COPIED Panda model -->
  <include file="../models/franka_emika_panda/panda.xml"/>

  <worldbody>
    <light pos="1 1 2" dir="-1 -1 -2" diffuse="0.9 0.9 0.9"/>

    <!-- Table -->
    <body name="table" pos="0.5 0 0">
      <geom type="box" size="0.35 0.25 0.02" pos="0 0 0.38"
            rgba="0.7 0.7 0.7 1"/>
      <geom type="box" size="0.03 0.03 0.38" pos="0 0 0.19"
            rgba="0.5 0.5 0.5 1"/>
    </body>

    <!-- Cube -->
    <body name="cube" pos="0.55 0 0.45">
      <freejoint/>
      <geom type="box" size="0.03 0.03 0.03"
            rgba="0.2 0.6 0.9 1" density="300"/>
    </body>

  </worldbody>
</mujoco>
