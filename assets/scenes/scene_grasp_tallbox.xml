<mujoco model="panda_grasp_tallbox">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" iterations="150" ls_iterations="150">
    <flag contact="enable" gravity="enable"/>
  </option>

  <visual>
    <global offwidth="1920" offheight="1080"/>
    <quality shadowsize="4096"/>
    <map force="0.1" zfar="30"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.1 0.2 0.3" rgb2="0.2 0.3 0.4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance="0.2"/>
  </asset>

  <!-- Franka Panda arm + gripper -->
  <include file="../models/franka_emika_panda/panda.xml"/>

  <worldbody>
    <light pos="0 0 3"   dir="0 0 -1"       directional="false" diffuse="0.8 0.8 0.8"/>
    <light pos="1.5 1.5 2" dir="-0.3 -0.3 -1" diffuse="0.5 0.5 0.5"/>

    <!-- Ground plane -->
    <geom name="floor" type="plane" size="0 0 1" pos="0 0 0"
          material="grid" condim="3" friction="0.8 0.01 0.0005"/>

    <!-- Table: centre at x=0.55, table top surface at z=0.42 m -->
    <body name="table" pos="0.55 0 0">
      <geom name="tabletop" type="box" size="0.30 0.40 0.02" pos="0 0 0.40"
            rgba="0.95 0.95 0.90 1" condim="3"
            friction="2.0 0.005 0.0001"
            solref="0.01 1" solimp="0.95 0.99 0.001"/>
      <geom name="leg1" type="cylinder" size="0.025 0.20" pos=" 0.25  0.35 0.20" rgba="0.55 0.55 0.55 1"/>
      <geom name="leg2" type="cylinder" size="0.025 0.20" pos="-0.25  0.35 0.20" rgba="0.55 0.55 0.55 1"/>
      <geom name="leg3" type="cylinder" size="0.025 0.20" pos=" 0.25 -0.35 0.20" rgba="0.55 0.55 0.55 1"/>
      <geom name="leg4" type="cylinder" size="0.025 0.20" pos="-0.25 -0.35 0.20" rgba="0.55 0.55 0.55 1"/>
    </body>

    <!--
      TALL BOX: 5×5×12 cm (half-extents: 0.025, 0.025, 0.06).
      Initial z=0.54: will settle to z≈0.48 (table_z=0.42 + half_height=0.06).
    -->
    <body name="cube" pos="0.55 0.00 0.54">
      <freejoint/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.06"
            rgba="0.95 0.35 0.20 1" mass="0.05" condim="4"
            friction="3.0 0.05 0.005"
            solref="0.004 1" solimp="0.99 0.999 0.0001"/>
      <site name="cube_center" pos="0 0 0" size="0.004" rgba="1 0 0 1"/>
    </body>
  </worldbody>

</mujoco>